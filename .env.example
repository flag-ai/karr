# Required
DATABASE_URL=postgres://karr:CHANGEME@localhost:5432/karr?sslmode=disable

# Required for docker-compose
POSTGRES_PASSWORD=CHANGEME
GF_ADMIN_PASSWORD=CHANGEME

# Optional — logging
LOG_LEVEL=info
LOG_FORMAT=text

# Optional — listen address
LISTEN_ADDR=:8080

# Optional — default BONNIE agent to register on startup
KARR_DEFAULT_AGENT_URL=
KARR_DEFAULT_AGENT_TOKEN=

# Optional — CORS allowed origins (comma-separated, empty = same-origin only)
# For development with Vite: http://localhost:5173
KARR_CORS_ORIGINS=

# Optional — OpenBao secrets provider
OPENBAO_ADDR=
OPENBAO_TOKEN=

# Integration tests
TEST_DATABASE_URL=postgres://karr:CHANGEME@localhost:5432/karr_test?sslmode=disable
