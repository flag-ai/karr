# Required
DATABASE_URL=postgres://karr:karr-dev@localhost:5432/karr?sslmode=disable

# Optional — logging
LOG_LEVEL=info
LOG_FORMAT=text

# Optional — listen address
LISTEN_ADDR=:8080

# Optional — default BONNIE agent to register on startup
KARR_DEFAULT_AGENT_URL=
KARR_DEFAULT_AGENT_TOKEN=

# Optional — OpenBao secrets provider
OPENBAO_ADDR=
OPENBAO_TOKEN=

# Integration tests
TEST_DATABASE_URL=postgres://karr:karr-test@localhost:5432/karr_test?sslmode=disable
