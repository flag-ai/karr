{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Prometheus Scrape Rate",
      "description": "Rate of Prometheus scrape requests to /metrics. Custom HTTP request metrics will be added in a future phase.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "showPoints": "never"
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(promhttp_metric_handler_requests_total[5m])",
          "legendFormat": "{{code}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Go Info",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#89b4fa", "mode": "fixed" },
          "mappings": [
            { "type": "value", "options": { "1": { "text": "Running", "color": "#a6e3a1" } } }
          ]
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "name"
      },
      "targets": [
        {
          "expr": "go_info",
          "legendFormat": "Go {{version}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "OS Threads",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#94e2d5", "mode": "fixed" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "go_threads",
          "legendFormat": "Threads",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Process Open FDs",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "showPoints": "never"
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "open" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#89b4fa", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "max" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#585b70", "mode": "fixed" } }, { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "process_open_fds",
          "legendFormat": "open",
          "refId": "A"
        },
        {
          "expr": "process_max_fds",
          "legendFormat": "max",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Go Goroutines",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#a6e3a1", "mode": "fixed" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "showPoints": "never"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "go_goroutines",
          "legendFormat": "goroutines",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Go Memory (Heap)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "showPoints": "never"
          },
          "unit": "bytes"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "alloc" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#89b4fa", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "sys" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#cba6f7", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "go_memstats_heap_alloc_bytes",
          "legendFormat": "alloc",
          "refId": "A"
        },
        {
          "expr": "go_memstats_heap_sys_bytes",
          "legendFormat": "sys",
          "refId": "B"
        }
      ]
    },
    {
      "title": "GC Pause Duration (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#fab387", "mode": "fixed" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "showPoints": "never"
          },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "go_gc_duration_seconds{quantile=\"0.95\"}",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Process Memory (RSS)",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#cba6f7", "mode": "fixed" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "showPoints": "never"
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "process_resident_memory_bytes",
          "legendFormat": "RSS",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Process CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#94e2d5", "mode": "fixed" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "showPoints": "never"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total[5m])",
          "legendFormat": "CPU cores",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["karr", "flag"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "KARR Overview",
  "uid": "karr-overview",
  "version": 2
}
